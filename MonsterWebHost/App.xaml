<Application x:Class="MonsterWebHost.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="PanelBrush" Color="#FF151515" />
            <SolidColorBrush x:Key="Panel2Brush" Color="#FF1E1E1E" />
            <SolidColorBrush x:Key="AccentBrush" Color="#FF6C63FF" />
            <SolidColorBrush x:Key="TextBrush" Color="#FFF2F2F2" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
